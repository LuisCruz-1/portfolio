---
const currentPath = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<nav class="global-bottom-nav box-gen" id="global-bottom-nav">
  <div class="nav-links">
    <!-- Active projector element -->
    <div class="nav-projector" id="nav-projector"></div>
    
    <a href={`${baseUrl}/#home`} class="nav-item" data-section="home">Inicio</a>
    <a href={`${baseUrl}/proyectos`} class="nav-item" data-section="proyectos">Proyectos</a>
    <a href={`${baseUrl}/servicios`} class="nav-item" data-section="servicios">Servicios</a>
    <a href={`${baseUrl}/#stack`} class="nav-item" data-section="stack">Stack</a>
    
    <div class="nav-divider"></div>
    
    <button class="theme-toggle" aria-label="Cambiar tema">
      <!-- Icono de Luna (Modo Oscuro) -->
      <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
      </svg>
      <!-- Icono de Sol (Modo Claro) -->
      <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2"></path>
        <path d="M12 20v2"></path>
        <path d="m4.93 4.93 1.41 1.41"></path>
        <path d="m17.66 17.66 1.41 1.41"></path>
        <path d="M2 12h2"></path>
        <path d="M20 12h2"></path>
        <path d="m6.34 17.66-1.41 1.41"></path>
        <path d="m19.07 4.93-1.41 1.41"></path>
      </svg>
    </button>
  </div>
</nav>

<style>
  .global-bottom-nav {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000;
    border-radius: 2rem;
    padding: 0.4rem;
    background: var(--nav-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--nav-border);
    box-shadow: 0 10px 40px -10px rgba(0,0,0,0.5);
    transition: all 0.3s ease;
  }

  .nav-links {
    display: flex;
    align-items: center;
    position: relative;
  }

  .nav-item {
    position: relative;
    z-index: 2;
    padding: 0.5rem 1rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    border-radius: 1.5rem;
    transition: color 0.3s ease;
  }

  .nav-item:hover {
    color: var(--text-main);
  }

  .nav-item.active {
    color: #171717; /* Contraste sobre el proyector verde */
    font-weight: 600;
  }

  .nav-projector {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    background-color: #a3e635; /* Color brand */
    border-radius: 1.5rem;
    z-index: 1;
    transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    opacity: 0;
    pointer-events: none;
  }

  .nav-divider {
    width: 1px;
    height: 1.2rem;
    background-color: var(--nav-divider);
    margin: 0 0.5rem;
  }

  .theme-toggle {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.3s ease, transform 0.3s ease;
    z-index: 2;
  }

  .theme-toggle:hover {
    color: var(--text-main);
    transform: rotate(45deg);
  }

  /* Logic for Theme Icons */
  :global([data-theme="light"]) .theme-toggle .moon-icon {
    display: block;
  }
  :global([data-theme="light"]) .theme-toggle .sun-icon {
    display: none;
  }
  .theme-toggle .moon-icon {
    display: none;
  }
  .theme-toggle .sun-icon {
    display: block;
  }

  @media (max-width: 640px) {
    .nav-item {
      padding: 0.5rem 0.75rem;
      font-size: 0.75rem;
    }
    .global-bottom-nav {
      width: 90vw;
      max-width: 400px;
    }
    .nav-links {
      justify-content: space-around;
      width: 100%;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Theme Toggle Logic
    const themeToggle = document.querySelector('.theme-toggle');
    const getPreferredTheme = () => {
      if (localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    };

    const setTheme = (theme) => {
      if (theme === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      } else {
        document.documentElement.removeAttribute('data-theme');
      }
      localStorage.setItem('theme', theme);
    };

    // Initialize theme
    setTheme(getPreferredTheme());

    if (themeToggle) {
      themeToggle.addEventListener('click', () => {
        const currentTheme = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
        const newTheme = currentTheme === 'light' ? 'dark' : 'light';
        setTheme(newTheme);
      });
    }

    const nav = document.getElementById('global-bottom-nav');
    const projector = document.getElementById('nav-projector');
    const items = document.querySelectorAll('.global-bottom-nav .nav-item');
    const sections = Array.from(items).map(item => document.getElementById(item.dataset.section)).filter(Boolean);
    
    if (!projector || !items.length) return;

    let currentActive = null;

    const updateProjector = (element) => {
      if (!element) {
        projector.style.opacity = '0';
        return;
      }
      const rect = element.getBoundingClientRect();
      const navRect = nav.getBoundingClientRect();
      
      projector.style.width = `${rect.width}px`;
      projector.style.transform = `translateX(${rect.left - navRect.left - 6}px)`; // offset for padding
      projector.style.opacity = '1';
    };

    const setActive = (item) => {
      items.forEach(i => i.classList.remove('active'));
      if (item) {
        item.classList.add('active');
        currentActive = item;
        updateProjector(item);
      } else {
        currentActive = null;
        updateProjector(null);
      }
    };

    // Scrollspy Logic
    if (sections.length > 0) {
      const observerOptions = {
        root: null,
        rootMargin: '-50% 0px -50% 0px',
        threshold: 0
      };

      const observer = new IntersectionObserver((entries) => {
        let visibleSection = null;
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            visibleSection = entry.target.id;
          }
        });

        if (visibleSection) {
          const targetItem = Array.from(items).find(item => item.dataset.section === visibleSection);
          if (targetItem) setActive(targetItem);
        }
      }, observerOptions);

      sections.forEach(section => observer.observe(section));
    } else {
      // If we are not on the index page (no sections found), maybe check pathname
      const path = window.location.pathname;
      if (path.includes('servicios')) {
        const servicesItem = Array.from(items).find(item => item.dataset.section === 'servicios');
        if (servicesItem) setActive(servicesItem);
      } else if (path.includes('proyectos')) {
        const projectsItem = Array.from(items).find(item => item.dataset.section === 'proyectos');
        if (projectsItem) setActive(projectsItem);
      } else {
        // Fallback for home if sections aren't strictly observed
        const homeItem = Array.from(items).find(item => item.dataset.section === 'home');
        if (homeItem) setActive(homeItem);
      }
    }

    // Hover effect
    items.forEach(item => {
      item.addEventListener('mouseenter', () => {
        updateProjector(item);
      });
    });

    document.querySelector('.nav-links').addEventListener('mouseleave', () => {
      updateProjector(currentActive);
    });

    // Smooth scroll for anchors
    items.forEach(item => {
      item.addEventListener('click', (e) => {
        const targetId = item.dataset.section;
        if (targetId === 'home' || targetId === 'stack') {
          const targetElement = document.getElementById(targetId);
          if (targetElement) {
            e.preventDefault();
            targetElement.scrollIntoView({ behavior: 'smooth' });
            // Optional: update URL hash without jump
            window.history.pushState(null, null, `#${targetId}`);
          }
        }
      });
    });
  });
</script>
