---
import '../styles/global.css';
import BottomNav from '../components/BottomNav.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Portafolio de Luis Cruz, desarrollador web y de aplicaciones con experiencia en la creación de soluciones eficientes e innovadoras." } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Luis Cruz" />

		<!-- Preconnect for Google Fonts (Inter + JetBrains Mono) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
		/>

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://luiscruz-1.github.io/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="https://luiscruz-1.github.io/images/og.png" />
		<meta property="og:site_name" content="Luis Cruz" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content="https://luiscruz-1.github.io/" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="https://luiscruz-1.github.io/images/og.png" />

		<link rel="icon" type="image/png" href="/images/favicon.svg" />
	</head>
	<body>
		<!--
		  ========================================
		  DEEP SPACE AURORA BACKGROUND
		  6 layers, strict stacking order:
		  1. Base canvas (wrapper bg + radial gradients)
		  2. Aurora blades (5 lights, animated)
		  3. Micro grid SVG (with inline <defs>)
		  4. Vignette
		  5. Letterbox (top cinematic highlight)
		  ========================================
		-->
		<div
			class="deep-space-bg fixed inset-0 overflow-hidden pointer-events-none -z-10"
			style="isolation: isolate;"
			aria-hidden="true"
		>
			<!-- Layer 2: Aurora Blade (single, centered) -->
			<div class="absolute inset-0">
				<div class="aurora-blade blade-center"></div>
			</div>

			<!-- Layer 3: Subtle Grid Overlay (inline SVG with internal <defs>) -->
			<svg
				class="deep-space-grid absolute inset-0 w-full h-full"
				xmlns="http://www.w3.org/2000/svg"
				preserveAspectRatio="xMidYMid slice"
				aria-hidden="true"
			>
				<defs>
					<pattern id="microGrid" x="0" y="0" width="60" height="60" patternUnits="userSpaceOnUse">
						<path
							d="M 60 0 L 0 0 0 60"
							fill="none"
							stroke="#003DCC"
							stroke-width="0.6"
						></path>
					</pattern>
				</defs>
				<rect width="100%" height="100%" fill="url(#microGrid)"></rect>
			</svg>

			<!-- Layer 4: Vignette -->
			<div class="deep-space-vignette"></div>

			<!-- Layer 5: Cinematic Letterbox -->
			<div class="deep-space-letterbox"></div>
		</div>

		<main class="w-full max-w-7xl px-4 sm:px-6 lg:px-8 pt-16 pb-24 relative z-10">
			<slot />
		</main>
		<BottomNav />
	</body>
</html>
