---
import Layout from '../layouts/Layout.astro';
import { projectsData } from '../data/data.js';

const projectsList = Object.entries(projectsData).map(([id, data]) => ({ id, ...data }));
---

<Layout title="Proyectos | Luis Cruz" description="Explora los proyectos de desarrollo web y de aplicaciones creados por Luis Cruz.">
  <header class="header">
    <a class="back-button" aria-label="Volver a inicio" href={`/`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left">
        <path d="m12 19-7-7 7-7"></path>
        <path d="M19 12H5"></path>
      </svg>
    </a>
    <h1>Proyectos que he realizado durante mi carrera.</h1>
    <p>¿No sabes por dónde empezar? He trabajado en montones de pequeños y grandes proyectos a lo largo de los años, pero estos son los que más me enorgullecen. Muchos de ellos son privados y no podré mostrarlos a continuación.</p>
  </header>

  <div class="projects-grid" id="projects-container">
    {projectsList.map(project => (
      <article class="project" data-project-id={project.id}>
        <div class="project-content">
          <img src={project.image} alt={project.title} loading="lazy" />
          <span class="project-meta">
            <p class="project-title">{project.title}</p>
            <p class="project-date">{project.date}</p>
          </span>
        </div>
        <button class="project-link" type="button">
          Detalles del Proyecto
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-up-right">
            <path d="M7 7h10v10"></path>
            <path d="M7 17 17 7"></path>
          </svg>
        </button>
      </article>
    ))}
  </div>

  <div id="project-modal" class="modal" role="dialog" aria-labelledby="project-title">
    <div class="modal-content">
      <span class="close-button" aria-label="Cerrar">&times;</span>
      <h2 id="project-title-modal"></h2>
      <h3 id="project-subtitle-modal"></h3>
      <p id="project-date-modal"></p>

      <div class="project-cover-container">
        <img id="project-cover-modal" src="" alt="Portada del proyecto" loading="lazy" />
      </div>

      <p id="project-description-modal"></p>

      <div id="project-link-container-modal" class="modal-link-container">
        <a id="project-link-modal" href="#" target="_blank" rel="noopener noreferrer" class="project-cta">
          Ver Proyecto
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M8.636 2.864a.5.5 0 0 1 .5-.5h5.793a.5.5 0 0 1 .5.5v5.793a.5.5 0 0 1-1 0V4.207L5.854 12.78a.5.5 0 1 1-.708-.708L13.719 3.5H9.136a.5.5 0 0 1-.5-.5z"/>
            <path fill-rule="evenodd" d="M2.5 14A1.5 1.5 0 0 1 1 12.5V3A1.5 1.5 0 0 1 2.5 1.5h4a.5.5 0 0 1 0 1h-4a.5.5 0 0 0-.5.5v9.5a.5.5 0 0 0 .5.5h9.5a.5.5 0 0 0 .5-.5v-4a.5.5 0 0 1 1 0v4A1.5 1.5 0 0 1 12.5 14h-10z"/>
          </svg>
        </a>
      </div>

      <div class="modal-navigation">
        <button id="prev-project" aria-label="Proyecto anterior" class="modal-nav-btn" type="button">Anterior</button>
        <button id="next-project" aria-label="Proyecto siguiente" class="modal-nav-btn" type="button">Siguiente</button>
      </div>
    </div>
  </div>

  <script>
    import { projectsData } from '../data/data.js';

    document.addEventListener("DOMContentLoaded", () => {
      const modal = document.getElementById("project-modal");
      const closeButton = modal?.querySelector(".close-button");
      const titleElement = document.getElementById("project-title-modal");
      const subtitleElement = document.getElementById("project-subtitle-modal");
      const dateElement = document.getElementById("project-date-modal");
      const coverElement = document.getElementById("project-cover-modal");
      const descElement = document.getElementById("project-description-modal");
      const linkContainer = document.getElementById("project-link-container-modal");
      const linkElement = document.getElementById("project-link-modal");
      const prevButton = document.getElementById("prev-project");
      const nextButton = document.getElementById("next-project");

      let currentProjectId = null;
      const projectIds = Object.keys(projectsData);

      function openModal(projectId) {
        if (!projectsData[projectId]) return;
        currentProjectId = projectId;
        const project = projectsData[projectId];

        if (titleElement) titleElement.textContent = project.title;
        if (subtitleElement) subtitleElement.textContent = project.subtitle;
        if (dateElement) dateElement.textContent = project.date;
        if (coverElement) coverElement.src = project.image;
        if (descElement) descElement.textContent = project.description;

        if (linkContainer && linkElement) {
          if (project.link && project.link.trim() !== "") {
            linkElement.href = project.link;
            linkContainer.style.display = "block";
          } else {
            linkContainer.style.display = "none";
          }
        }

        updateNavigationButtons();

        if (modal) {
          modal.style.display = "block";
          setTimeout(() => modal.classList.add("show"), 10);
        }
        document.body.style.overflow = "hidden";
      }

      function closeModal() {
        if (modal) {
          modal.classList.remove("show");
          setTimeout(() => {
            modal.style.display = "none";
            document.body.style.overflow = "";
          }, 300);
        }
      }

      function updateNavigationButtons() {
        const currentIndex = projectIds.indexOf(currentProjectId);
        if (prevButton) prevButton.disabled = currentIndex === 0;
        if (nextButton) nextButton.disabled = currentIndex === projectIds.length - 1;
      }

      const projectCards = document.querySelectorAll(".project");
      projectCards.forEach((card) => {
        card.addEventListener("click", () => {
          const projectId = card.getAttribute("data-project-id");
          if (projectId) openModal(projectId);
        });
      });

      if (closeButton) closeButton.addEventListener("click", closeModal);

      window.addEventListener("click", (event) => {
        if (event.target === modal) closeModal();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && modal?.classList.contains("show")) {
          closeModal();
        }
        if (modal?.classList.contains("show")) {
          if (event.key === "ArrowLeft" && prevButton && !prevButton.disabled) {
            navigateProject(-1);
          } else if (event.key === "ArrowRight" && nextButton && !nextButton.disabled) {
            navigateProject(1);
          }
        }
      });

      function navigateProject(direction) {
        const currentIndex = projectIds.indexOf(currentProjectId);
        const newIndex = currentIndex + direction;
        if (newIndex >= 0 && newIndex < projectIds.length) {
          openModal(projectIds[newIndex]);
        }
      }

      if (prevButton) prevButton.addEventListener("click", () => navigateProject(-1));
      if (nextButton) nextButton.addEventListener("click", () => navigateProject(1));
    });
  </script>
</Layout>

<style>
  .header { margin-top: 2rem; }
  .header h1 {
    font-size: 2.5rem;
    line-height: 1.2;
    font-weight: 800;
    letter-spacing: -0.05em;
    color: var(--color-fg);
    margin-bottom: 1rem;
  }
  .header p {
    margin-top: 1.5rem;
    font-size: 1rem;
    color: var(--color-fg-muted);
    max-width: 640px;
  }

  .back-button {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    border-radius: 9999px;
    width: 2.5rem;
    height: 2.5rem;
    color: var(--color-fg);
    transition: transform 0.3s ease;
    border: 1px solid var(--color-border);
    background: var(--color-glass);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    margin-bottom: 2rem;
  }
  .back-button:hover { transform: translateX(-4px); }
  .back-button svg { width: 1rem; height: 1rem; }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    margin-top: 4rem;
  }
  @media (min-width: 640px) { .projects-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .projects-grid { grid-template-columns: repeat(4, 1fr); } }

  .project {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    border-radius: 0.75rem;
    overflow: hidden;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    padding: 0.35rem;
    max-height: 220px;
    cursor: pointer;
    border: 1px solid var(--color-border);
    background: var(--color-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .project:hover {
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
    transform: translateY(-4px);
  }
  .project-content {
    overflow: hidden;
    position: relative;
    border-radius: 0.375rem;
    height: 100%;
  }
  .project-content img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.5rem;
    display: block;
  }
  .project-meta {
    background: linear-gradient(to top, rgba(0, 0, 0, 1), transparent);
    display: flex;
    position: absolute;
    bottom: 0;
    z-index: 1;
    padding: 1rem;
    flex-direction: row;
    flex-wrap: nowrap;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 2.9rem;
    color: #ffffff;
  }
  .project-title { font-size: 0.875rem; font-weight: 500; }
  .project-date { font-size: 0.75rem; opacity: 0.8; }

  .project-link {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: center;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    width: 100%;
    font-size: 0.875rem;
    line-height: 1.5rem;
    font-weight: 500;
    background: var(--color-glass);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: all 0.3s ease;
    color: var(--color-fg);
    cursor: pointer;
    font-family: var(--font-body);
  }
  .project-link:hover {
    background: var(--color-nav);
    border-color: var(--color-border);
  }

  /* Modal (Micrudev cinematic) */
  .modal {
    display: none;
    position: fixed;
    z-index: 100;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: auto;
    background-color: rgba(4, 11, 31, 0.7);
    backdrop-filter: blur(12px) saturate(120%);
    -webkit-backdrop-filter: blur(12px) saturate(120%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  [data-theme="light"] .modal { background-color: rgba(246, 248, 252, 0.7); }
  .modal.show { opacity: 1; }
  .modal-content {
    margin: 5% auto;
    padding: 2.5rem;
    width: 90%;
    border-radius: 1rem;
    max-width: 800px;
    transform: translateY(-20px) scale(0.95);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    color: var(--color-fg);
    background-color: var(--color-modal) !important;
    background-image: linear-gradient(180deg, rgba(76, 132, 255, 0.05) 0%, rgba(76, 132, 255, 0) 100%);
    border: 1px solid var(--color-border);
    backdrop-filter: blur(24px) saturate(150%);
    -webkit-backdrop-filter: blur(24px) saturate(150%);
    box-shadow:
      0 25px 50px -12px rgba(2, 83, 253, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }
  .modal-content h2 { font-size: 2rem; line-height: 2.5rem; }
  .modal-content h3 {
    font-weight: 300;
    color: var(--color-fg-muted);
    font-size: 1.1rem;
    line-height: 1.5rem;
    margin-top: 0.5rem;
  }
  .modal-content p#project-date-modal {
    font-weight: 200;
    font-size: 0.9rem;
    color: var(--color-fg-muted);
    margin-bottom: 1.5rem;
  }
  .modal-content p#project-description-modal {
    margin-top: 1.5rem;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-fg-muted);
  }
  .modal.show .modal-content {
    transform: translateY(0) scale(1);
  }
  .close-button {
    color: var(--color-fg-muted);
    float: right;
    font-size: 38px;
    cursor: pointer;
    transition: color 0.3s, transform 0.3s;
    line-height: 1;
  }
  .close-button:hover, .close-button:focus {
    color: var(--color-amber);
    transform: rotate(90deg);
  }

  .project-cover-container {
    width: 100%;
    height: 300px;
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background-color: rgba(4, 11, 31, 0.5);
    background-image: linear-gradient(180deg, rgba(2, 83, 253, 0.1) 0%, transparent 100%);
    margin-bottom: 1.5rem;
  }
  .project-cover-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .modal-link-container { margin-top: 2rem; display: none; }
  .project-cta {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 2rem;
    border: 1px solid var(--color-border);
    font-size: 0.875rem;
    font-weight: 500;
    background: linear-gradient(135deg, var(--color-coral) 0%, var(--color-amber) 100%);
    color: #ffffff;
    box-shadow: 0 0 16px rgba(76, 132, 255, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.15);
    transition: all 0.3s ease;
  }
  .project-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(2, 83, 253, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  .modal-navigation {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
  }
  .modal-nav-btn {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: center;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    font-size: 0.875rem;
    font-weight: 500;
    background: var(--color-glass);
    backdrop-filter: blur(8px);
    transition: all 0.3s ease;
    color: var(--color-fg);
    cursor: pointer;
    font-family: var(--font-body);
  }
  .modal-nav-btn:hover {
    background: var(--color-nav);
    border-color: rgba(76, 132, 255, 0.3);
  }
  .modal-nav-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
</style>
