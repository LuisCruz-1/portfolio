  <!-- Stack Modal -->
  <div id="stack-modal" class="modal">
    <div class="modal-content" style="width: fit-content!important;">
      <span class="close-button" aria-label="Cerrar">&times;</span>
      <h2 style="font-size: 1.5rem; margin-bottom: 1.5rem; text-align: center;">
        Stack Tecnológico
      </h2>
      <div class="stack-modal-grid-wrapper">
        <div id="stack-modal-grid" class="stack-modal-grid">
          {stackData.map(tech => (
            <div class={`stack-icon ${tech.isWide ? 'flutterflow-icon' : ''}`} style={tech.isWide ? 'grid-column: span 2' : ''} title={tech.name}>
              {tech.isWide ? (
                <>
                  <img src={tech.icon} alt={tech.name} style="width: 24px; height: 24px;" />
                  <span>{tech.name}</span>
                </>
              ) : (
                <img src={tech.icon} alt={tech.name} loading="lazy" />
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <script>
    // Lógica del Modal (Ejecutada en el cliente)
    document.addEventListener("DOMContentLoaded", () => {
      const openBtn = document.getElementById('open-stack-modal');
      const stackModal = document.getElementById('stack-modal');
      const closeBtn = stackModal ? stackModal.querySelector('.close-button') : null;

      if (openBtn && stackModal) {
        openBtn.addEventListener('click', (e) => {
          e.preventDefault();
          stackModal.style.display = 'block';
          // Pequeño delay para la transición de CSS
          setTimeout(() => stackModal.classList.add('show'), 10);
          document.body.style.overflow = 'hidden';
        });
      }

      if (closeBtn && stackModal) {
        closeBtn.addEventListener('click', () => {
          stackModal.classList.remove('show');
          setTimeout(() => {
            stackModal.style.display = 'none';
            document.body.style.overflow = '';
          }, 300);
        });
      }

      window.addEventListener('click', (event) => {
        if (event.target === stackModal) {
          stackModal.classList.remove('show');
          setTimeout(() => {
            stackModal.style.display = 'none';
            document.body.style.overflow = '';
          }, 300);
        }
      });
    });
  </script>
</Layout>
