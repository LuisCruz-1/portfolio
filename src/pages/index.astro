      <div id="container-stack" class="stack-mask-wrapper">
        <div class="stack-track" id="stack-track">
          <div class="stack-grid" id="main-stack-grid">
            {stackData.map(tech => (
              <div class={`stack-icon ${tech.isWide ? 'flutterflow-icon' : ''}`} style={`grid-area: ${tech.gridArea}`} title={tech.name}>
                {tech.isWide ? (
                  <>
                    <img src={tech.icon} alt={tech.name} style="width: 24px; height: 24px;" />
                    <span>{tech.name}</span>
                  </>
                ) : (
                  <img src={tech.icon} alt={tech.name} loading="lazy" />
                )}
              </div>
            ))}
          </div>
          <!-- Clone for infinite marquee loop (rendered statically) -->
          <div class="stack-grid" aria-hidden="true">
            {stackData.map(tech => (
              <div class={`stack-icon ${tech.isWide ? 'flutterflow-icon' : ''}`} style={`grid-area: ${tech.gridArea}`} title={tech.name}>
                {tech.isWide ? (
                  <>
                    <img src={tech.icon} alt={tech.name} style="width: 24px; height: 24px;" />
                    <span>{tech.name}</span>
                  </>
                ) : (
