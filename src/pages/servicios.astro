---
import Layout from '../layouts/Layout.astro';
import { webDevelopmentPlans, otherServices, faqData, priceFactors } from '../data/services.js';
import '../styles/services.css';
---

<Layout title="Servicios | Luis Cruz" description="Servicios de desarrollo web, aplicaciones a medida y automatizaciones ofrecidos por Luis Cruz.">
  <!-- Ambient Glow -->
  <div class="ambient-glow"></div>

  <div class="top-nav">
    <a class="box-gen back-button shadow" aria-label="Volver a inicio" href={`/`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left">
        <path d="m12 19-7-7 7-7"></path>
        <path d="M19 12H5"></path>
      </svg>
    </a>
  </div>

  <!-- Navegación Lateral (Scrollspy) -->
  <nav class="side-nav" aria-label="Navegación de secciones">
    <ul>
      <li>
        <a href="#web" class="nav-dot active">
          <span class="nav-label">Desarrollo Web</span>
        </a>
      </li>
      <li>
        <a href="#custom" class="nav-dot">
          <span class="nav-label">Soluciones Personalizadas</span>
        </a>
      </li>
    </ul>
  </nav>

  <!-- Desarrollo Web -->
  <section id="web" class="service-category">
    <div class="category-title text-center">
      <span class="badge box-gen">Páginas Web</span>
      <h2>Desarrollo de Sitios Web</h2>
      <p>Construimos tu presencia digital con velocidad, diseño excepcional y listos para SEO.</p>
    </div>

    <div class="section-heading">
      <span class="eyebrow">PRECIOS REFERENCIALES</span>
      <h3>¿Cuánto cuesta tu sitio web?</h3>
      <p class="disclaimer">No trabajo con precios fijos porque cada negocio tiene necesidades diferentes. Aquí encontrarás una referencia clara de lo que puedes esperar según el tipo de sitio web que buscas antes de ponerte en contacto.</p>
    </div>

    <div class="pricing-grid">
      {webDevelopmentPlans.map((plan, index) => (
        <div class={`pricing-card box-gen shadow ${index === 1 ? 'popular' : ''}`}>
          {index === 1 && <div class="popular-badge">RECOMENDADO</div>}
          
          <!-- Segmented Top Bar -->
          <div class="segmented-bar">
            <div class={`segment ${index >= 0 ? 'active' : ''}`}></div>
            <div class={`segment ${index >= 1 ? 'active' : ''}`}></div>
            <div class={`segment ${index >= 2 ? 'active' : ''}`}></div>
          </div>

          <div class="plan-header">
            <h3>{plan.name}</h3>
            <p class="description">{plan.description}</p>
            <div class="price-container">
              <span class="price">{plan.price}</span>
            </div>
          </div>

          <div class="plan-features">
            <ul>
              {plan.features.map(feature => (
                <li>
                  <div class="check-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  </div>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="plan-footer">
            <div class="time-estimate">
              <span class="time-label">Tiempo estimado</span>
              <span class="time-value">{plan.time}</span>
            </div>
            <a href="https://wa.me/593998081684" target="_blank" rel="noopener noreferrer" class="btn-quote">
              Solicitar cotización
            </a>
            <button class="btn-details-link" data-details={plan.details} data-title={plan.name}>
              <span>Ver detalles del servicio</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </button>
          </div>
        </div>
      ))}
    </div>
    
    <div class="pricing-note">
      <p>Estos rangos reflejan el tiempo relativo y la complejidad de cada servicio, no precios fijos. El costo final depende de tu proyecto específico, incluyendo el número de páginas, el contenido a agregar y las integraciones requeridas.</p>
    </div>

    <!-- FAQ y Factores de Precio en Grid Split -->
    <div class="pricing-info-split mt-section">
      <div class="factors-side">
        <div class="factors-header">
          <h3>Qué Determina el Precio Final</h3>
          <p>Discutiremos todo esto antes de que comience el proyecto, para que no haya sorpresas después.</p>
        </div>
        
        <div class="factors-grid">
          {priceFactors.map(factor => (
            <div class="factor-item">
              <h4>{factor.title}</h4>
              <p>{factor.description}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="faq-side">
        <div class="faq-header">
          <span class="eyebrow">FAQ</span>
          <h3>Preguntas Frecuentes</h3>
          <p>Las preguntas que más recibo antes de preparar una cotización.</p>
        </div>

        <div class="faq-container">
          {faqData.map((faq, index) => (
            <div class="faq-item-clean">
              <button class="faq-question" aria-expanded="false" aria-controls={`faq-answer-${index}`}>
                <span>{faq.question}</span>
                <div class="plus-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                </div>
              </button>
              <div id={`faq-answer-${index}`} class="faq-answer">
                <div class="faq-answer-inner">
                  <p>{faq.answer}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <hr class="category-divider" />

  <!-- Otros Servicios -->
  <section id="custom" class="service-category">
    <div class="category-title text-center">
      <span class="badge box-gen">Otros Servicios</span>
      <h2>Soluciones Personalizadas</h2>
      <p>Aplicaciones a medida, integraciones y herramientas tecnológicas para optimizar tus procesos.</p>
    </div>

    <div class="bento-services mt-section">
      {otherServices.map((service, i) => (
        <div id={service.id} class={`bento-card box-gen shadow card-${i}`}>
          <div class="bento-content">
            <div class="bento-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
            </div>
            <h2>{service.title}</h2>
            <h3>{service.description}</h3>
            <p>{service.content}</p>
          </div>
          <div class="bento-action">
            <a href="https://wa.me/593998081684" target="_blank" rel="noopener noreferrer" class="bento-btn box-gen">
              Agendar Consulta
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Modal Detalles de Plan -->
  <div id="plan-modal" class="modal" role="dialog" aria-labelledby="plan-modal-title">
    <div class="modal-content glass-modal">
      <span class="close-button" aria-label="Cerrar">&times;</span>
      <div class="modal-header-glow"></div>
      <h2 id="plan-modal-title"></h2>
      <p id="plan-modal-details"></p>

      <div class="modal-actions">
        <a href="https://wa.me/593998081684" target="_blank" rel="noopener noreferrer" class="btn-primary">
          Iniciar Proyecto
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        </a>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Scrollspy Logic para el Side Nav
      const sections = document.querySelectorAll('.service-category');
      const navDots = document.querySelectorAll('.nav-dot');

      if (sections.length > 0 && navDots.length > 0) {
        const observerOptions = {
          root: null,
          rootMargin: '-20% 0px -60% 0px', // Ajustado para activar cuando la sección llega al top
          threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const currentId = entry.target.getAttribute('id');
              navDots.forEach(dot => {
                dot.classList.remove('active');
                if (dot.getAttribute('href') === `#${currentId}`) {
                  dot.classList.add('active');
                }
              });
            }
          });
        }, observerOptions);

        sections.forEach(section => observer.observe(section));
      }

      // Modal Logic
      const modal = document.getElementById("plan-modal");
      const closeBtn = modal?.querySelector(".close-button");
      const titleEl = document.getElementById("plan-modal-title");
      const detailsEl = document.getElementById("plan-modal-details");

      document.querySelectorAll(".btn-details-link").forEach(btn => {
        btn.addEventListener("click", () => {
          if (titleEl && detailsEl) {
            titleEl.textContent = btn.getAttribute("data-title");
            detailsEl.textContent = btn.getAttribute("data-details");
          }
          if (modal) {
            modal.style.display = "block";
            setTimeout(() => modal.classList.add("show"), 10);
            document.body.style.overflow = "hidden";
          }
        });
      });

      function closeModal() {
        if (modal) {
          modal.classList.remove("show");
          setTimeout(() => {
            modal.style.display = "none";
            document.body.style.overflow = "";
          }, 300);
        }
      }

      if (closeBtn) closeBtn.addEventListener("click", closeModal);
      window.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && modal?.classList.contains("show")) closeModal();
      });

      // FAQ Accordion Logic
      document.querySelectorAll(".faq-question").forEach(button => {
        button.addEventListener("click", () => {
          const isExpanded = button.getAttribute("aria-expanded") === "true";

          // Close all other accordions
          document.querySelectorAll(".faq-question").forEach(otherBtn => {
            if (otherBtn !== button) {
              otherBtn.setAttribute("aria-expanded", "false");
              const otherAnswer = document.getElementById(otherBtn.getAttribute("aria-controls"));
              if (otherAnswer) otherAnswer.style.maxHeight = null;
            }
          });

          // Toggle current
          button.setAttribute("aria-expanded", !isExpanded);
          const answer = document.getElementById(button.getAttribute("aria-controls"));

          if (answer) {
            if (!isExpanded) {
              answer.style.maxHeight = answer.scrollHeight + "px";
            } else {
              answer.style.maxHeight = null;
            }
          }
        });
      });
    });
  </script>
</Layout>